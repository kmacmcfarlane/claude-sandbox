#!/usr/bin/env bash
#
# Run Claude Code inside a sandboxed Docker container.
#
# Usage:
#   claude-sandbox                          # launch claude interactively in $PWD
#   claude-sandbox --resume                 # pass args through to claude
#   claude-sandbox --dangerous              # skip permission prompts (synonym for --dangerously-skip-permissions)
#   claude-sandbox --docker-socket           # mount the host Docker socket
#   claude-sandbox --aws                     # mount ~/.aws/ read-only
#   claude-sandbox --ralph [ralph-args]     # launch the ralph loop runner
#   claude-sandbox --ralph --limit 5        # run ralph for 5 iterations
#   PROJECT_DIR=/other claude-sandbox       # launch claude in /other
#
# The project is mounted at its REAL host path inside the container so that
# docker compose volumes (which the host daemon resolves) work correctly.
#
set -euo  pipefail

REAL_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$REAL_PATH")/.." && pwd)"
echo REPO_ROOT=${REPO_ROOT}
BASE_IMAGE_NAME="claude-sandbox"

# Walk parent directories (direnv-style) looking for a file.
# Usage: find_up <start_dir> <filename>
# Prints the full path if found, empty string otherwise.
find_up() {
    local dir="$1" name="$2"
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/$name" ]; then
            echo "$dir/$name"
            return
        fi
        dir="$(dirname "$dir")"
    done
}

# ---------------------------------------------------------------------------
# Parse claude-sandbox flags; remaining args pass through to claude/ralph
# ---------------------------------------------------------------------------
RALPH_MODE=false
LIMIT=""
SKIP_PERMISSIONS=""
DOCKER_SOCKET="${CLAUDE_SANDBOX_DOCKER_SOCKET:-false}"
AWS_MOUNT="${CLAUDE_SANDBOX_AWS:-false}"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --ralph)
            RALPH_MODE=true; shift ;;
        --limit)
            LIMIT="${2:-}"
            if [[ -z "$LIMIT" ]]; then
                echo "Error: --limit requires a value" >&2; exit 2
            fi
            shift 2 ;;
        --dangerous|--dangerously-skip-permissions)
            SKIP_PERMISSIONS="--dangerously-skip-permissions"; shift ;;
        --docker-socket)
            DOCKER_SOCKET=true; shift ;;
        --aws)
            AWS_MOUNT=true; shift ;;
        *)
            break ;;
    esac
done

# Normalize env var values to boolean
if [[ "$DOCKER_SOCKET" = "1" || "$DOCKER_SOCKET" = "true" ]]; then
    DOCKER_SOCKET=true
fi
if [[ "$AWS_MOUNT" = "1" || "$AWS_MOUNT" = "true" ]]; then
    AWS_MOUNT=true
fi

if [[ -n "$LIMIT" && "$RALPH_MODE" = false ]]; then
    echo "Error: --limit is only valid with --ralph" >&2
    exit 2
fi

# ---------------------------------------------------------------------------
# Resolve project directory (must be absolute for the same-path mount trick)
# ---------------------------------------------------------------------------
PROJECT_DIR="${PROJECT_DIR:-$(pwd)}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"

# ---------------------------------------------------------------------------
# Detect host IDs for permission mapping
# ---------------------------------------------------------------------------
HOST_UID="$(id -u)"
HOST_GID="$(id -g)"
DOCKER_GID=""
if [ "$DOCKER_SOCKET" = true ]; then
    DOCKER_GID="$(stat -c '%g' /var/run/docker.sock 2>/dev/null || echo '')"
fi

# ---------------------------------------------------------------------------
# Build base image if needed (must happen before volume assembly which uses it)
# ---------------------------------------------------------------------------
BASE_NEEDS_BUILD=false
if ! docker image inspect "$BASE_IMAGE_NAME" >/dev/null 2>&1; then
    BASE_NEEDS_BUILD=true
elif [ "$REPO_ROOT/Dockerfile" -nt "$(docker image inspect -f '{{.Created}}' "$BASE_IMAGE_NAME" 2>/dev/null || echo '1970')" ]; then
    BASE_NEEDS_BUILD=true
fi

if [ "$BASE_NEEDS_BUILD" = true ]; then
    echo "Building $BASE_IMAGE_NAME base image..."
    docker build -t "$BASE_IMAGE_NAME" "$REPO_ROOT"
fi

# ---------------------------------------------------------------------------
# Assemble volume mounts
# ---------------------------------------------------------------------------
VOLUMES=(
    # Mount project at its real host path so docker-in-docker volume paths match
    -v "$PROJECT_DIR:$PROJECT_DIR"
)

# Docker socket for host docker access (opt-in via --docker-socket)
if [ "$DOCKER_SOCKET" = true ]; then
    VOLUMES+=(-v /var/run/docker.sock:/var/run/docker.sock)
fi

# AWS credentials/config (opt-in via --aws)
if [ "$AWS_MOUNT" = true ] && [ -d "$HOME/.aws" ]; then
    VOLUMES+=(-v "$HOME/.aws:$HOME/.aws:ro")
fi

# Claude Code config directory (auth tokens, project memories, settings)
# Mounted at its real host path so absolute paths recorded by Claude Code
# (e.g. plugin installPath values) resolve identically inside the container.
CLAUDE_CONFIG_HOST="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
if [ -d "$CLAUDE_CONFIG_HOST" ]; then
    VOLUMES+=(-v "$CLAUDE_CONFIG_HOST:$CLAUDE_CONFIG_HOST")
fi

# Merge host CLAUDE.md with container context for in-container awareness
CLAUDE_MD_TMP=$(mktemp)
SETTINGS_TMP=$(mktemp)
trap "rm -f '$CLAUDE_MD_TMP' '$SETTINGS_TMP'" EXIT
cat "$CLAUDE_CONFIG_HOST/CLAUDE.md" 2>/dev/null >> "$CLAUDE_MD_TMP" || true
printf '\n' >> "$CLAUDE_MD_TMP"
cat "$REPO_ROOT/container-context.md" >> "$CLAUDE_MD_TMP"
VOLUMES+=(-v "$CLAUDE_MD_TMP:$CLAUDE_CONFIG_HOST/CLAUDE.md:ro")

# Merge notification hooks into user settings (shadowed read-only so host file is untouched)
HOST_SETTINGS="$CLAUDE_CONFIG_HOST/settings.json"
HOOKS_FRAGMENT="$REPO_ROOT/notification-hooks.json"
if [ -f "$HOST_SETTINGS" ] && [ -f "$HOOKS_FRAGMENT" ]; then
    docker run --rm \
        -v "$HOST_SETTINGS:/input.json:ro" \
        -v "$HOOKS_FRAGMENT:/hooks.json:ro" \
        "$BASE_IMAGE_NAME" node -e '
            const a = require("/input.json");
            const b = require("/hooks.json");
            console.log(JSON.stringify({ ...a, ...b }, null, 2));
        ' > "$SETTINGS_TMP"
    VOLUMES+=(-v "$SETTINGS_TMP:$CLAUDE_CONFIG_HOST/settings.json:ro")
elif [ -f "$HOOKS_FRAGMENT" ]; then
    # No host settings.json — use hooks fragment as-is
    cp "$HOOKS_FRAGMENT" "$SETTINGS_TMP"
    VOLUMES+=(-v "$SETTINGS_TMP:$CLAUDE_CONFIG_HOST/settings.json:ro")
fi

# Sibling files alongside the config directory (.claude.json, .mcp.json).
# Mirrors the $HOME pattern: $HOME/.claude/ sits next to $HOME/.claude.json
# and $HOME/.mcp.json. When CLAUDE_CONFIG_DIR relocates the config dir,
# the same sibling relationship applies at the parent of that directory.
CONFIG_PARENT="$(dirname "$CLAUDE_CONFIG_HOST")"
if [ -f "$CONFIG_PARENT/.claude.json" ]; then
    VOLUMES+=(-v "$CONFIG_PARENT/.claude.json:$CONFIG_PARENT/.claude.json")
fi
if [ -f "$CONFIG_PARENT/.mcp.json" ]; then
    VOLUMES+=(-v "$CONFIG_PARENT/.mcp.json:$CONFIG_PARENT/.mcp.json:ro")
fi

# Git config (for commits)
if [ -f "$HOME/.gitconfig" ]; then
    VOLUMES+=(-v "$HOME/.gitconfig:$HOME/.gitconfig:ro")
fi

# SSH keys (for git remotes over SSH)
if [ -d "$HOME/.ssh" ]; then
    VOLUMES+=(-v "$HOME/.ssh:$HOME/.ssh:ro")
fi

# ---------------------------------------------------------------------------
# Parse .claude-sandbox.yaml (memory limit, extra mounts, etc.)
# ---------------------------------------------------------------------------
CONFIG_FILE="$(find_up "$PROJECT_DIR" ".claude-sandbox.yaml")"
MEMORY_LIMIT="8g"

if [ -f "$CONFIG_FILE" ]; then
    if ! command -v yq &>/dev/null; then
        echo "Error: .claude-sandbox.yaml found but 'yq' is not installed." >&2
        echo "" >&2
        echo "yq is required to parse the config file. Install it with:" >&2
        echo "  brew install yq          # macOS (Homebrew)" >&2
        echo "  sudo snap install yq     # Ubuntu/Debian (snap)" >&2
        echo "  go install github.com/mikefarah/yq/v4@latest  # Go" >&2
        echo "" >&2
        echo "More options: https://github.com/mikefarah/yq#install" >&2
        exit 1
    fi

    # Memory limit (default: 8g)
    CONFIG_MEMORY=$(yq '.memoryLimit // ""' "$CONFIG_FILE")
    if [ -n "$CONFIG_MEMORY" ]; then
        MEMORY_LIMIT="$CONFIG_MEMORY"
    fi

    # Extra volume mounts
    MOUNT_COUNT=$(yq '.mounts | length' "$CONFIG_FILE")
    for ((i = 0; i < MOUNT_COUNT; i++)); do
        MOUNT_HOST=$(yq ".mounts[$i].host" "$CONFIG_FILE")
        MOUNT_CONTAINER=$(yq ".mounts[$i].container" "$CONFIG_FILE")
        MOUNT_WRITABLE=$(yq ".mounts[$i].writable // false" "$CONFIG_FILE")

        if [ "$MOUNT_HOST" = "null" ] || [ "$MOUNT_CONTAINER" = "null" ]; then
            echo "Error: mounts[$i] in $CONFIG_FILE requires both 'host' and 'container' fields" >&2
            exit 1
        fi

        if [ "$MOUNT_WRITABLE" = "true" ]; then
            VOLUMES+=(-v "$MOUNT_HOST:$MOUNT_CONTAINER")
        else
            VOLUMES+=(-v "$MOUNT_HOST:$MOUNT_CONTAINER:ro")
        fi
    done
fi

# ---------------------------------------------------------------------------
# Resolve child Dockerfile (project-specific tools layer)
# Precedence: env var > .claude-sandbox.yaml > default
# ---------------------------------------------------------------------------
CONFIG_BASE_ONLY=""
CONFIG_DOCKERFILE_DIR=""
CONFIG_DOCKERFILE=""
if [ -f "$CONFIG_FILE" ]; then
    CONFIG_BASE_ONLY=$(yq '.baseOnly // ""' "$CONFIG_FILE")
    CONFIG_DOCKERFILE_DIR=$(yq '.dockerfileDir // ""' "$CONFIG_FILE")
    CONFIG_DOCKERFILE=$(yq '.dockerfile // ""' "$CONFIG_FILE")
fi

BASE_ONLY="${CLAUDE_SANDBOX_BASE_ONLY:-$CONFIG_BASE_ONLY}"
CHILD_DOCKERFILE_DIR="${CLAUDE_SANDBOX_DOCKERFILE_DIR:-${CONFIG_DOCKERFILE_DIR:-$PROJECT_DIR}}"
CHILD_DOCKERFILE_NAME="${CLAUDE_SANDBOX_DOCKERFILE:-${CONFIG_DOCKERFILE:-Dockerfile.claude-sandbox}}"
CHILD_DOCKERFILE="${CHILD_DOCKERFILE_DIR}/${CHILD_DOCKERFILE_NAME}"

USE_CHILD=false
if [ "$BASE_ONLY" = "true" ] || [ "$BASE_ONLY" = "1" ]; then
    USE_CHILD=false
elif [ -f "$CHILD_DOCKERFILE" ]; then
    USE_CHILD=true
else
    # Walk parent directories (direnv-style) looking for the Dockerfile
    _found="$(find_up "$(dirname "$CHILD_DOCKERFILE_DIR")" "$CHILD_DOCKERFILE_NAME")"
    if [ -n "$_found" ]; then
        CHILD_DOCKERFILE_DIR="$(dirname "$_found")"
        CHILD_DOCKERFILE="$_found"
        USE_CHILD=true
        echo "Found $CHILD_DOCKERFILE_NAME in parent directory: $CHILD_DOCKERFILE_DIR"
    fi
fi

# ---------------------------------------------------------------------------
# Build child image if a project Dockerfile exists, or fall back to base
# ---------------------------------------------------------------------------
PROJECT_SLUG="$(basename "$PROJECT_DIR" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g')"

if [ "$USE_CHILD" = true ]; then
    CHILD_IMAGE_NAME="claude-sandbox-${PROJECT_SLUG}"

    CHILD_NEEDS_BUILD=false
    if ! docker image inspect "$CHILD_IMAGE_NAME" >/dev/null 2>&1; then
        CHILD_NEEDS_BUILD=true
    elif [ "$BASE_NEEDS_BUILD" = true ]; then
        # Base was rebuilt — child must be rebuilt too
        CHILD_NEEDS_BUILD=true
    elif [ "$CHILD_DOCKERFILE" -nt "$(docker image inspect -f '{{.Created}}' "$CHILD_IMAGE_NAME" 2>/dev/null || echo '1970')" ]; then
        CHILD_NEEDS_BUILD=true
    fi

    if [ "$CHILD_NEEDS_BUILD" = true ]; then
        echo "Building $CHILD_IMAGE_NAME child image from $CHILD_DOCKERFILE..."
        docker build -t "$CHILD_IMAGE_NAME" -f "$CHILD_DOCKERFILE" "$CHILD_DOCKERFILE_DIR"
    fi

    IMAGE_NAME="$CHILD_IMAGE_NAME"
else
    if [ "$BASE_ONLY" != "true" ] && [ "$BASE_ONLY" != "1" ]; then
        echo "WARNING: No child Dockerfile found at $CHILD_DOCKERFILE" >&2
        echo "  Project-specific tools (Go, TypeScript LSP, etc.) will not be available." >&2
        echo "  Create a Dockerfile.claude-sandbox in your project root to add them," >&2
        echo "  or set baseOnly: true in .claude-sandbox.yaml to suppress this warning." >&2
        echo "" >&2
    fi
    IMAGE_NAME="$BASE_IMAGE_NAME"
fi

# ---------------------------------------------------------------------------
# Claude environment file (Discord webhook, etc.)
# ---------------------------------------------------------------------------
ENV_FILE="$(find_up "$PROJECT_DIR" ".env.claude-sandbox")"
if [ -n "$ENV_FILE" ]; then
    ENV_ARGS=(--env-file "$ENV_FILE")
else
    ENV_ARGS=()
    echo "WARNING: .env.claude-sandbox not found in $PROJECT_DIR or any parent" >&2
    echo "" >&2
    echo "This file provides environment variables needed by Claude Code" >&2
    echo "(e.g. DISCORD_WEBHOOK_URL for MCP server notifications)." >&2
    echo "" >&2
    echo "To create it, copy the example and fill in your values:" >&2
    echo "  cp .env.claude-sandbox.example .env.claude-sandbox" >&2
fi

# ---------------------------------------------------------------------------
# Build container command
# ---------------------------------------------------------------------------
if [ "$RALPH_MODE" = true ]; then
    CONTAINER_NAME="claude-sandbox-${PROJECT_SLUG}-ralph"
    CMD=("/opt/claude-sandbox/bin/ralph")
    [[ -n "$LIMIT" ]] && CMD+=("--limit" "$LIMIT")
    [[ -n "$SKIP_PERMISSIONS" ]] && CMD+=("$SKIP_PERMISSIONS")
    CMD+=("$@")
else
    CONTAINER_NAME="claude-sandbox-${PROJECT_SLUG}"
    CMD=("claude")
    [[ -n "$SKIP_PERMISSIONS" ]] && CMD+=("$SKIP_PERMISSIONS")
    CMD+=("$@")
fi

# ---------------------------------------------------------------------------
# Launch
# ---------------------------------------------------------------------------
CLAUDE_CONFIG_DIR_ENV=()
if [ -n "${CLAUDE_CONFIG_DIR:-}" ]; then
    CLAUDE_CONFIG_DIR_ENV=(-e "CLAUDE_CONFIG_DIR=$CLAUDE_CONFIG_DIR")
fi

exec docker run -it --rm --init \
    "${VOLUMES[@]}" \
    -w "$PROJECT_DIR" \
    "${ENV_ARGS[@]}" \
    --memory "$MEMORY_LIMIT" \
    --memory-swap "$MEMORY_LIMIT" \
    -e HOST_UID="$HOST_UID" \
    -e HOST_GID="$HOST_GID" \
    -e HOST_USER="$(whoami)" \
    -e HOST_HOME="$HOME" \
    -e HOME="$HOME" \
    -e DOCKER_GID="$DOCKER_GID" \
    -e ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}" \
    "${CLAUDE_CONFIG_DIR_ENV[@]}" \
    --name "$CONTAINER_NAME" \
    "$IMAGE_NAME" \
    "${CMD[@]}"
