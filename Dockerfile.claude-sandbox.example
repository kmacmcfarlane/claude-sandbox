# Dockerfile.claude-sandbox — project-specific tools for claude-sandbox
#
# Place as Dockerfile.claude-sandbox in your project root (or configure the
# path via .claude-sandbox.yaml or environment variables).
#
# The build context is the directory containing this file, so COPY instructions
# reference your project directory.
#
# USER CONVENTION:
#   The base image's entrypoint runs as root, remaps the "claude" user to match
#   the host caller's UID/GID, then drops privileges via gosu. It also chowns
#   all non-bind-mounted files under the home directory at startup.
#
#   - Use "USER claude" for RUN steps that create files under /home/claude
#     (e.g. go install, pip install --user, writing to ~/.cache).
#   - Use /home/claude (not a hardcoded host path like /home/yourname) so the
#     image is portable across host users.
#   - End with "USER root" so the entrypoint has the privileges it needs.

FROM claude-sandbox

# --- Go toolchain -----------------------------------------------------------
# RUN curl -fsSL https://go.dev/dl/go1.25.6.linux-amd64.tar.gz | tar -C /usr/local -xz
# ENV PATH="/usr/local/go/bin:$PATH"

# --- Go language server (gopls) — install as claude user for ~/go/bin --------
# USER claude
# RUN go install golang.org/x/tools/gopls@latest
# USER root
# ENV PATH="/home/claude/go/bin:$PATH"

# --- TypeScript / JavaScript language servers --------------------------------
# RUN npm install -g typescript-language-server typescript && \
#     npm install -g @vtsls/language-server

# --- Python packages (venv is already active from base image) ----------------
# RUN pip install --no-cache-dir numpy pandas

# --- Files under /home/claude (use USER claude so they're owned correctly) ---
# USER claude
# RUN mkdir -p /home/claude/.cache/myapp \
#     && echo "hello" > /home/claude/.cache/myapp/config
# USER root
